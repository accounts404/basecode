import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

// Función helper para normalizar fechas al formato YYYY-MM-DD
const normalizeDateToYYYYMMDD = (dateInput) => {
    if (!dateInput) return null;
    
    // Si ya está en formato YYYY-MM-DD, devolverlo tal cual
    if (typeof dateInput === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(dateInput)) {
        return dateInput;
    }
    
    // Si es un Date object o cualquier otro formato, convertir a YYYY-MM-DD
    try {
        const date = new Date(dateInput);
        if (isNaN(date.getTime())) return null;
        
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        
        return `${year}-${month}-${day}`;
    } catch (error) {
        console.error('[getDailyTeamAssignments] Error normalizando fecha:', error);
        return null;
    }
};

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        
        const user = await base44.auth.me();
        if (!user) {
            return Response.json({ error: 'Unauthorized' }, { status: 401 });
        }

        // Obtener la fecha del body de la request (en formato YYYY-MM-DD)
        const body = await req.json().catch(() => ({}));
        const targetDate = body.date; // Formato esperado: 'YYYY-MM-DD'

        console.log('[getDailyTeamAssignments] 🔍 Buscando asignaciones para fecha:', targetDate);

        // Usar service role para obtener todas las asignaciones, vehículos y usuarios
        const [assignments, vehicles, users] = await Promise.all([
            base44.asServiceRole.entities.DailyTeamAssignment.list(),
            base44.asServiceRole.entities.Vehicle.list(),
            base44.asServiceRole.entities.User.list()
        ]);
        
        console.log('[getDailyTeamAssignments] 📋 Total de asignaciones en DB:', assignments.length);
        
        // Si se proporciona una fecha, filtrar por esa fecha (con normalización)
        let filteredAssignments = assignments;
        if (targetDate) {
            const normalizedTargetDate = normalizeDateToYYYYMMDD(targetDate);
            
            filteredAssignments = assignments.filter(a => {
                const normalizedAssignmentDate = normalizeDateToYYYYMMDD(a.date);
                const match = normalizedAssignmentDate === normalizedTargetDate;
                
                if (match) {
                    console.log('[getDailyTeamAssignments] ✅ Asignación encontrada:', {
                        original: a.date,
                        normalized: normalizedAssignmentDate,
                        target: normalizedTargetDate,
                        vehicle_id: a.vehicle_id,
                        team_member_ids: a.team_member_ids
                    });
                }
                
                return match;
            });
            
            console.log('[getDailyTeamAssignments] 🎯 Asignaciones filtradas para', targetDate, ':', filteredAssignments.length);
        }
        
        // Crear mapas para búsqueda rápida
        const vehicleMap = new Map(vehicles.map(v => [v.id, v]));
        const userMap = new Map(users.map(u => [u.id, u]));

        // Enriquecer las asignaciones con los detalles del vehículo, conductor principal y compañeros
        const enrichedAssignments = filteredAssignments.map(assignment => {
            const enrichedAssignment = { ...assignment };

            // NORMALIZAR team_member_ids si no es un array
            if (assignment.team_member_ids && !Array.isArray(assignment.team_member_ids)) {
                console.log('[getDailyTeamAssignments] ⚠️ team_member_ids no es array:', assignment.team_member_ids);
                
                // Si es string, intentar parsearlo o convertirlo en array
                if (typeof assignment.team_member_ids === 'string') {
                    // Eliminar caracteres especiales como "×" y dividir por comas
                    const cleanedString = assignment.team_member_ids.replace(/[×\s]/g, '');
                    enrichedAssignment.team_member_ids = [cleanedString];
                } else {
                    enrichedAssignment.team_member_ids = [assignment.team_member_ids];
                }
                
                console.log('[getDailyTeamAssignments] 🔧 team_member_ids normalizado:', enrichedAssignment.team_member_ids);
            }

            // Añadir detalles del vehículo si existe
            if (assignment.vehicle_id) {
                const vehicle = vehicleMap.get(assignment.vehicle_id);
                if (vehicle) {
                    enrichedAssignment.vehicle_details = {
                        make: vehicle.make,
                        model: vehicle.model,
                        license_plate: vehicle.license_plate,
                        photos: vehicle.photos || []
                    };
                    // Información legible del vehículo
                    enrichedAssignment.vehicle_info = `${vehicle.make} ${vehicle.model} (${vehicle.license_plate})`;
                    
                    console.log('[getDailyTeamAssignments] 🚗 Vehículo enriquecido:', enrichedAssignment.vehicle_info);
                } else {
                    console.log('[getDailyTeamAssignments] ⚠️ Vehículo no encontrado con ID:', assignment.vehicle_id);
                }
            }

            // Añadir información del conductor principal
            if (assignment.main_driver_id) {
                const mainDriver = userMap.get(assignment.main_driver_id);
                if (mainDriver) {
                    enrichedAssignment.main_driver_name = mainDriver.display_name || mainDriver.invoice_name || mainDriver.full_name;
                    console.log('[getDailyTeamAssignments] 👤 Conductor principal:', enrichedAssignment.main_driver_name);
                }
            }

            // Mantener compatibilidad hacia atrás con driver_name
            if (assignment.driver_id && !enrichedAssignment.driver_name) {
                const driver = userMap.get(assignment.driver_id);
                if (driver) {
                    enrichedAssignment.driver_name = driver.invoice_name || driver.full_name;
                }
            }

            // Añadir nombres de todos los compañeros de equipo
            if (enrichedAssignment.team_member_ids && Array.isArray(enrichedAssignment.team_member_ids)) {
                enrichedAssignment.team_members_info = enrichedAssignment.team_member_ids
                    .map(memberId => {
                        const member = userMap.get(memberId);
                        if (member) {
                            return {
                                id: memberId,
                                name: member.display_name || member.invoice_name || member.full_name,
                                is_main_driver: memberId === assignment.main_driver_id
                            };
                        }
                        return null;
                    })
                    .filter(Boolean);
                
                console.log('[getDailyTeamAssignments] 👥 Miembros del equipo:', enrichedAssignment.team_members_info.length);
            }

            return enrichedAssignment;
        });
        
        console.log('[getDailyTeamAssignments] ✅ Respuesta final con', enrichedAssignments.length, 'asignaciones enriquecidas');
        
        return Response.json({ 
            success: true,
            assignments: enrichedAssignments 
        });

    } catch (error) {
        console.error('[getDailyTeamAssignments] ❌ Error:', error);
        return Response.json({ 
            error: 'Error obteniendo asignaciones de equipos',
            details: error.message 
        }, { status: 500 });
    }
});