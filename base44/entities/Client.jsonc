    "oven_cleaning_services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "service_date": {
            "type": "string",
            "format": "date"
          },
          "amount_charged": {
            "type": "number"
          },
          "service_description": {
            "type": "string"
          },
