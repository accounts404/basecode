{
  "name": "Client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nombre del cliente"
    },
    "sms_name": {
      "type": "string",
      "description": "Nombre corto para usar en mensajes SMS"
    },
    "client_type": {
      "type": "string",
      "enum": [
        "domestic",
        "commercial",
        "training",
        "ndis_client",
        "dva_client",
        "age_care_client",
        "work_cover_client"
      ],
      "default": "domestic",
      "description": "Tipo de cliente"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Fecha en que el cliente inici\u00f3 con la empresa"
    },
    "end_date": {
      "type": "string",
      "format": "date",
      "description": "Fecha en que el cliente dej\u00f3 de ser cliente"
    },
    "funding_document_url": {
      "type": "string"
    },
    "funding_document_start_date": {
      "type": "string",
      "format": "date"
    },
    "funding_document_end_date": {
      "type": "string",
      "format": "date"
    },
    "mobile_number": {
      "type": "string"
    },
    "secondary_mobile_number": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "property_type": {
      "type": "string",
      "enum": [
        "house",
        "townhouse",
        "unit",
        "apartment"
      ]
    },
    "property_stories": {
      "type": "string",
      "enum": [
        "single_storey",
        "double_storey",
        "triple_storey",
        "other"
      ]
    },
    "num_bedrooms": {
      "type": "number"
    },
    "num_bathrooms": {
      "type": "number"
    },
    "email": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "service_frequency": {
      "type": "string",
      "enum": [
        "weekly",
        "fortnightly",
        "every_3_weeks",
        "monthly",
        "one_off"
      ]
    },
    "current_service_price": {
      "type": "number"
    },
    "service_hours": {
      "type": "number"
    },
    "gst_type": {
      "type": "string",
      "enum": [
        "inclusive",
        "exclusive",
        "no_tax"
      ],
      "default": "inclusive"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "bank_transfer",
        "cash",
        "credit_card",
        "gocardless",
        "stripe",
        "other"
      ],
      "default": "bank_transfer"
    },
    "has_special_billing_instructions": {
      "type": "boolean",
      "default": false
    },
    "special_billing_instructions": {
      "type": "string"
    },
    "admin_notes": {
      "type": "string"
    },
    "pets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "breed": {
            "type": "string"
          },
          "age": {
            "type": "string"
          },
          "temperament": {
            "type": "string"
          },
          "special_instructions": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "type"
        ]
      }
    },
    "family_details": {
      "type": "object",
      "properties": {
        "spouse_name": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "family_notes": {
          "type": "string"
        },
        "emergency_contact": {
          "type": "string"
        }
      }
    },
    "has_access": {
      "type": "boolean",
      "default": false
    },
    "access_type": {
      "type": "string",
      "enum": [
        "key",
        "smart_lock",
        "lockbox",
        "other"
      ]
    },
    "access_identifier": {
      "type": "string"
    },
    "access_instructions": {
      "type": "string"
    },
    "access_photos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    "default_service_notes": {
      "type": "string"
    },
    "default_photo_urls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    "structured_service_notes": {
      "type": "object",
      "properties": {
        "dusting_wiping_tidyup": {
          "type": "object",
          "properties": {
            "notes": {
              "type": "string"
            },
            "photos": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        },
        "kitchen_and_pantry": {
          "type": "object",
          "properties": {
            "notes": {
              "type": "string"
            },
            "photos": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        },
        "bathrooms": {
          "type": "object",
          "properties": {
            "notes": {
              "type": "string"
            },
            "photos": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        },
        "laundry": {
          "type": "object",
          "properties": {
            "notes": {
              "type": "string"
            },
            "photos": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        },
        "floors": {
          "type": "object",
          "properties": {
            "notes": {
              "type": "string"
            },
            "photos": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        },
        "other_areas": {
          "type": "object",
          "properties": {
            "notes": {
              "type": "string"
            },
            "photos": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        }
      }
    },
    "price_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "previous_price": {
            "type": "number"
          },
          "new_price": {
            "type": "number"
          },
          "effective_date": {
            "type": "string",
            "format": "date"
          },
          "percentage_increase": {
            "type": "number"
          },
          "comments": {
            "type": "string"
          },
          "gst_type": {
            "type": "string",
            "enum": [
              "inclusive",
              "exclusive",
              "no_tax"
            ]
          },
          "payment_method": {
            "type": "string",
            "enum": [
              "bank_transfer",
              "cash",
              "credit_card",
              "gocardless",
              "stripe",
              "other"
            ]
          }
        },
        "required": [
          "previous_price",
          "new_price",
          "effective_date"
        ]
      }
    },
    "price_increase_notifications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sent_date": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
