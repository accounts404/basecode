    "last_updated_by_id": {
      "type": "string",
      "description": "ID del usuario que realiz\u00f3 la \u00faltima modificaci\u00f3n del registro"
    },
    "last_updated_by_name": {
      "type": "string",
      "description": "Nombre del usuario que realiz\u00f3 la \u00faltima modificaci\u00f3n"
    },
    "last_updated_by_email": {
      "type": "string",
